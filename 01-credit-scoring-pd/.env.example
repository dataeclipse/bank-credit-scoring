# Пример окружения. Скопируй в .env и заполни. .env в .gitignore - НЕ коммить.
# Все переменные сервиса - с префиксом PD_.

PD_ENV=local
PD_LOG_LEVEL=INFO
PD_RANDOM_SEED=42

# Витрина фичей в PostgreSQL (Фаза 1+). Реальные креды - только тут, не в коде.
PD_DATABASE_URL=postgresql+psycopg://scoring:scoring@localhost:5432/scoring

# MLflow tracking (Фаза 2+).
PD_MLFLOW_TRACKING_URI=http://localhost:5000

# Пути проекта.
PD_DATA_DIR=data
PD_MODEL_DIR=artifacts/models

# Kaggle creds для загрузки Home Credit (Фаза 1). Альтернатива - ~/.kaggle/kaggle.json.
# kaggle.json НИКОГДА не коммить (в .gitignore).
# KAGGLE_USERNAME=
# KAGGLE_KEY=
