# Environment example. Copy to .env and fill in. .env is in .gitignore - do NOT commit.
# All service variables are prefixed with PD_.

PD_ENV=local
PD_LOG_LEVEL=INFO
PD_RANDOM_SEED=42

# Feature mart in PostgreSQL (Phase 1+). Real credentials - only here, not in code.
PD_DATABASE_URL=postgresql+psycopg://scoring:scoring@localhost:5432/scoring

# MLflow tracking (Phase 2+).
PD_MLFLOW_TRACKING_URI=http://localhost:5000

# Project paths.
PD_DATA_DIR=data
PD_MODEL_DIR=artifacts/models

# Kaggle credentials for downloading Home Credit (Phase 1). Alternative - ~/.kaggle/kaggle.json.
# NEVER commit kaggle.json (it is in .gitignore).
# KAGGLE_USERNAME=
# KAGGLE_KEY=
