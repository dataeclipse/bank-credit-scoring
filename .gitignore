# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# --- Virtual envs ---
.venv/
venv/

# --- Environment / secrets (секреты НИКОГДА не коммитим) ---
.env
.env.*
!.env.example
kaggle.json
.kaggle/

# --- Data (датасеты не коммитим; держим только README) ---
# Только датасеты в <project>/data/ — НЕ Python-пакет src/.../data/ (его возвращаем ниже).
**/data/*
!**/data/README.md
!**/src/**/*.py

# --- ML artifacts / tracking ---
mlruns/
mlartifacts/
mlflow.db
*.db
artifacts/

# --- Запечённая модель для Docker (создаётся pd-scoring-export-model) ---
**/deploy/*
!**/deploy/.gitkeep
*.parquet
*.pkl
*.joblib
*.cbm

# --- Logs ---
*.log

# --- Сгенерированные тяжёлые отчёты (Evidently HTML и пр.) ---
**/docs/**/*.html
**/evidently_*.html

# --- Caches ---
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# --- Notebooks ---
.ipynb_checkpoints/

# --- OS / editors ---
.DS_Store
Thumbs.db
.idea/
.vscode/
